//- team_stats.pug
include ../partials/header.pug
include ../partials/menu.pug

div.container
  br
  div.jumbotron
    h1.display-4 Fall 2018 Stats
    p.lead CU Football Statistics for the 2018 Football Season!

  table.table.table-bordered#stats_table
    tr
      th.text-center(colspan="2") Score
      th.align-bottom(rowspan="2") Game Date
      th.align-bottom(rowspan="2") Winner
      th.align-bottom(rowspan="2") Opposing Team Name
    tr
      th Home Score
      th Opp. Score
    form(action='/home/team_stats',method=get)
      for item in result_1
        tr
          td #{item.home_score}
          td #{item.visitor_score}
          td #{item.game_date}
          td #{item.visitor_name}
          if (item.visitor_score <= item.home_score)
            td CU Boulder
          else
            td #{item.visitor_name}
  br

  table.table.text-center
    tr
      th Wins
      th Losses
    tr
      form(action='/home_team_stats',method=get)
        for item in result_2
          td #{item.count}
      form(action='/home_team_stats',method=get)
        for item in result_3
          td #{item.count} 

include ../partials/footer.pug
